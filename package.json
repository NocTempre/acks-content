{
  "name": "acks-content",
  "version": "1.0.0",
  "description": "Dev tooling for the ACKS II Content Streamer (PoC) Foundry module. Not loaded by Foundry at runtime.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:packs": "node tools/build-packs.mjs",
    "validate": "node tools/validate.mjs",
    "lint:register": "node tools/lint-register.mjs",
    "check:drift": "node tools/check-cookbook-drift.mjs",
    "harvest": "node tools/harvest-page.mjs",
    "harvest:index": "node tools/harvest-index.mjs",
    "compile": "node tools/compile-cookbook.mjs",
    "verify:cookbook": "node tools/verify-cookbook.mjs",
    "ledger": "node tools/ledger-init.mjs",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^1.0.0",
    "classic-level": "^3.0.0",
    "handlebars": "^4.7.9",
    "pdfjs-dist": "^6.1.200"
  }
}
