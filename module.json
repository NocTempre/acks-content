{
  "id": "acks-content",
  "title": "ACKS II — Content Streamer (PoC)",
  "description": "Streams book prose from the user's own ACKS II PDFs into Foundry at render time — per-client, bring-your-own-book. PoC.",
  "version": "0.22.0",
  "authors": [
    {
      "name": "NocTempre"
    }
  ],
  "license": "LICENSE",
  "compatibility": {
    "minimum": "14",
    "verified": "14.364"
  },
  "relationships": {
    "systems": [
      {
        "id": "acks",
        "type": "system",
        "compatibility": {
          "minimum": "14"
        }
      }
    ],
    "recommends": [
      {
        "id": "game-icons-net",
        "type": "module",
        "reason": "Niche ability icons for the ACKS-shaped corners of the corpus (Acrobatics, Blind Fighting, Caving, Mapping). Optional: without it every ability falls back to a core Foundry icon."
      }
    ]
  },
  "manifest": "https://github.com/NocTempre/acks-content/releases/latest/download/module.json",
  "download": "https://github.com/NocTempre/acks-content/releases/latest/download/module.zip",
  "flags": {
    "acks-content": {
      "idPrefix": "acksc"
    }
  },
  "esmodules": [
    "scripts/module.mjs"
  ],
  "styles": [
    "styles/module.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "packs": [
    {
      "name": "macros",
      "label": "ACKS Content — Macros",
      "path": "packs/macros",
      "type": "Macro",
      "system": "acks"
    }
  ]
}
