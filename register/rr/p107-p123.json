  {
    "id": "def.prof.alchemy",
    "kind": "kind.proficiency",
    "book": "rr",
    "name": "Alchemy",
    "anchor": {
      "display": "Alchemy (G)"
    },
    "pages": [
      107
    ],
    "meta": {
      "category": "proficiency",
      "general": true,
      "repeatable": true
    },
    "rolls": [
      {
        "key": "identifySubstance",
        "label": {
          "pattern": "(identify \\w+ alchemical substances)"
        },
        "target": {
          "on": "rank",
          "pattern": "identify \\w+ alchemical substances[\\s\\S]{0,80}?of (\\d+)\\+[\\s\\S]{0,1200}?identify substances[^.;]{0,30}?(\\d+)\\+[\\s\\S]{0,600}?identify substances[^.;]{0,30}?(\\d+)\\+"
        },
        "condition": "one turn; by aroma and color"
      },
      {
        "key": "identifyComponents",
        "label": {
          "pattern": "(identify special components)"
        },
        "target": {
          "on": "rank",
          "pattern": "identify which parts[\\s\\S]{0,90}?throw of (\\d+)\\+[\\s\\S]{0,1200}?special components on (\\d+)\\+[\\s\\S]{0,600}?special components on (\\d+)\\+"
        },
        "note": "Identifies which parts of a monster are special components."
      },
      {
        "key": "extractToxinFresh",
        "label": {
          "pattern": "of \\d+\\+ for (fresh plants)"
        },
        "target": {
          "on": "rank",
          "pattern": "of (\\d+)\\+ for fresh[\\s\\S]{0,900}?toxins on (\\d+)\\+\\s*/[\\s\\S]{0,600}?toxins on (\\d+)\\+\\s*/"
        },
        "condition": "one day of dedicated activity",
        "note": "Extracting toxin from poisonous plants; one dose on a success, spoiled plants on a failure. On an unmodified 1 the character is exposed and must make a Death saving throw."
      },
      {
        "key": "extractToxinDried",
        "label": {
          "pattern": "and \\d+\\+ for (dried plants)"
        },
        "target": {
          "on": "rank",
          "pattern": "and (\\d+)\\+ for dried[\\s\\S]{0,900}?toxins on \\d+\\+\\s*/\\s*(\\d+)\\+[\\s\\S]{0,600}?toxins on \\d+\\+\\s*/\\s*(\\d+)\\+"
        },
        "condition": "one day of dedicated activity",
        "note": "Extracting toxin from poisonous plants; one dose on a success, spoiled plants on a failure. On an unmodified 1 the character is exposed and must make a Death saving throw."
      }
    ]
  },
